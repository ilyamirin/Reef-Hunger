{
  "name": "reef-hunger-arcade",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "hooks:install": "git config core.hooksPath .githooks",
    "dev": "vite",
    "dev:pages": "VITE_BASE_PATH=/ vite",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "typecheck": "tsc -b --pretty false",
    "security:secrets": "secretlint \"**/*\"",
    "verify": "pnpm lint && pnpm format && pnpm typecheck && pnpm security:secrets && pnpm build",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,js,mjs,cjs,css,html,json,md,yml,yaml}": [
      "secretlint"
    ]
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.6.0",
    "@types/node": "^24.6.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "lint-staged": "^16.2.1",
    "prettier": "^3.6.2",
    "secretlint": "^11.6.0",
    "typescript-eslint": "^8.46.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  }
}
